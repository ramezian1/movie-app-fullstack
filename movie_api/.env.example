# Copy this file to .env and fill in your values
# Never commit the actual .env file to source control

# A strong random secret key for signing JWT tokens
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SQLAlchemy database URL
# For development: sqlite:///./movies.db
# For production: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./movies.db

# Comma-separated list of allowed CORS origins
# Example for production: https://your-frontend.com
CORS_ORIGINS=["http://localhost:5173"]
